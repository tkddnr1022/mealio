// PostgreSQL 데이터소스 (Producer/Consumer 공용)
datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "generated"
  moduleFormat = "cjs"
}

model User {
  id                 Int      @id @default(autoincrement())
  email              String   @unique @db.VarChar(100)
  nickname           String   @db.VarChar(50)
  platformName       String   @map("platform_name") @db.VarChar(20)
  platformId         String   @map("platform_id") @db.VarChar(100)
  /** 남은 챗봇 크레딧 (0이면 신규 메시지 전송 불가). 신규 행 값은 앱에서 `DEFAULT_USER_CREDIT_*`로 주입 */
  creditBalance      Int      @default(0) @map("credit_balance")
  /** UI 상한·월간 기준 등에 사용하는 한도(남은 잔액과 별도). 신규 행 값은 앱에서 `DEFAULT_USER_CREDIT_*`로 주입 */
  creditMonthlyLimit Int      @default(0) @map("credit_monthly_limit")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  chatbotCreditDeductions ChatbotCreditDeduction[]
  recommendations         UserRecipeRecommendation[]
  authRefreshSessions     AuthRefreshSession[]

  @@index([platformName, platformId])
  @@index([email])
  @@index([createdAt])
  @@map("User")
}

model AuthRefreshSession {
  id                  String  @id @db.Uuid
  userId              Int     @map("user_id")
  tokenHash           String  @map("token_hash") @db.VarChar(128)
  expiresAt           DateTime @map("expires_at")
  revokedAt           DateTime? @map("revoked_at")
  replacedBySessionId String? @map("replaced_by_session_id") @db.Uuid
  lastUsedAt          DateTime? @map("last_used_at")
  userAgent           String? @map("user_agent") @db.VarChar(512)
  ipAddress           String? @map("ip_address") @db.VarChar(64)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy AuthRefreshSession? @relation("AuthRefreshSessionReplacement", fields: [replacedBySessionId], references: [id])
  replaces   AuthRefreshSession[] @relation("AuthRefreshSessionReplacement")

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([replacedBySessionId])
  @@map("auth_refresh_sessions")
}

/** 챗봇 요청당 1회 차감 멱등 (Kafka 재시도 시 이중 차감 방지) */
model ChatbotCreditDeduction {
  streamChannelId String   @id @map("stream_channel_id") @db.VarChar(80)
  userId          Int      @map("user_id")
  credits         Int      @map("credits")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("chatbot_credit_deductions")
}

model Recipe {
  id           Int      @id @default(autoincrement())
  categoryId   Int
  title        String   @db.VarChar(100)
  description  String?  @db.Text
  instructions Json
  difficulty   Int      @db.SmallInt
  cookTime     Int      @map("cook_time")
  imageUrl     String?  @map("image_url") @db.VarChar(512)
  servings     Int      @default(2)
  cookingMethod String? @map("cooking_method") @db.VarChar(50)
  dishType     String?  @map("dish_type") @db.VarChar(50)
  nutrition    Json?
  cookingTip   String?  @map("cooking_tip") @db.Text
  source       String?  @db.VarChar(50)
  sourceRecipeId String? @map("source_recipe_id") @db.VarChar(50)
  isPublished  Boolean  @default(true) @map("is_published")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  categoryMeta      RecipeCategory     @relation(fields: [categoryId], references: [id])
  recipeIngredients RecipeIngredient[]
  stats             RecipeStats?
  recommendedTo     UserRecipeRecommendation[]
  embedding         RecipeEmbedding?

  @@unique([source, sourceRecipeId])
  @@index([categoryId, difficulty, cookTime, createdAt])
  @@index([difficulty, cookTime, createdAt])
  @@index([createdAt(sort: Desc)])
  @@map("Recipe")
}

model RecipeEmbedding {
  recipeId       Int                      @id @map("recipe_id")
  /** pgvector extension type. Prisma Client에서는 raw query로 접근한다. */
  embedding      Unsupported("vector")
  embeddingModel String                   @map("embedding_model") @db.VarChar(100)
  version        Int                      @default(1)
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @default(now()) @updatedAt @map("updated_at")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([updatedAt(sort: Desc)])
  @@map("RecipeEmbedding")
}

model RecipeStats {
  recipeId   Int      @id @map("recipe_id")
  viewCount  Int      @default(0) @map("view_count")
  likeCount  Int      @default(0) @map("like_count")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([viewCount(sort: Desc), recipeId(sort: Desc)])
  @@index([likeCount(sort: Desc), recipeId(sort: Desc)])
  @@map("RecipeStats")
}

model RecipeCategory {
  id           Int      @id
  key          String   @unique @db.VarChar(50)
  name         String   @db.VarChar(100)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  recipes Recipe[]

  @@index([isActive, displayOrder])
  @@map("RecipeCategory")
}

model IngredientCategory {
  id           Int      @id
  key          String   @unique @db.VarChar(50)
  name         String   @db.VarChar(100)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  ingredients Ingredient[]

  @@index([isActive, displayOrder])
  @@map("IngredientCategory")
}

model Ingredient {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  categoryId Int
  createdAt  DateTime @default(now()) @map("created_at")

  categoryMeta      IngredientCategory @relation(fields: [categoryId], references: [id])
  embedding         IngredientEmbedding?
  recipeIngredients RecipeIngredient[]

  @@index([categoryId, name])
  @@map("Ingredient")
}

model IngredientEmbedding {
  ingredientId   Int                   @id @map("ingredient_id")
  /** pgvector extension type. Prisma Client에서는 raw query로 접근한다. */
  embedding      Unsupported("vector")
  embeddingModel String                @map("embedding_model") @db.VarChar(100)
  version        Int                   @default(1)
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @default(now()) @updatedAt @map("updated_at")

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([updatedAt(sort: Desc)])
  @@map("IngredientEmbedding")
}

model RecipeIngredient {
  id           Int      @id @default(autoincrement())
  recipeId     Int      @map("recipe_id")
  ingredientId Int      @map("ingredient_id")
  amount       Decimal? @db.Decimal(10, 2)
  unit         String?  @db.VarChar(20)
  isOptional   Boolean  @default(false) @map("is_optional")

  recipe     Recipe     @relation(fields: [recipeId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
  @@index([recipeId])
  @@index([ingredientId])
  @@map("RecipeIngredient")
}

model UserRecipeRecommendation {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  recipeId     Int      @map("recipe_id")
  rank         Int      @map("rank")
  score        Decimal  @db.Decimal(10, 4)
  reason       String?  @db.VarChar(255)
  calculatedAt DateTime @map("calculated_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@unique([userId, rank])
  @@index([userId, score(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
  @@map("UserRecipeRecommendation")
}
