NODE_ENV=development
PORT=3000
JWT_SECRET=a-string-secret-at-least-256-bits-long
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=1209600
REFRESH_TOKEN_BYTES=48
POSTGRESQL_URL=postgresql://devuser:devpassword@localhost:5432/devdb
MONGODB_URL=mongodb://devuser:devpassword@localhost:27017/devdb?authSource=admin
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=mealio-producer
GOOGLE_CLIENT_ID=example.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=example-secret
KAKAO_CLIENT_ID=example-client-id
KAKAO_CLIENT_SECRET=example-client-secret
NAVER_CLIENT_ID=example-client-id
NAVER_CLIENT_SECRET=example-client-secret
OAUTH_CALLBACK_BASE_URL=http://localhost:3000
OAUTH_STATE_TTL_SEC=600
FRONTEND_APP_BASE_URL=http://localhost:4000
FRONTEND_OAUTH_ERROR_PATH=/oauth/error
FRONTEND_OAUTH_DEFAULT_SUCCESS_PATH=/recipe
SENTRY_ENABLED=false
SENTRY_DSN_PRODUCER=
METRICS_ENABLED=true
SLOW_QUERY_THRESHOLD_MS=500
