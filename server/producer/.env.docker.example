# docker
APP_ENV=development
MEMORY_LIMIT=768M
DOCKERHUB_USERNAME=local

# common
PORT=3000
JWT_SECRET=a-string-secret-at-least-256-bits-long
POSTGRESQL_URL=postgresql://devuser:devpassword@postgres:5432/devdb
MONGODB_URL=mongodb://devuser:devpassword@mongodb:27017/devdb?authSource=admin
REDIS_URL=redis://:devpassword@redis:6379
KAFKA_BROKERS=kafka:19092
KAFKA_CLIENT_ID=mealio-producer
GOOGLE_CLIENT_ID=example.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=example-secret
KAKAO_CLIENT_ID=example-client-id
KAKAO_CLIENT_SECRET=example-client-secret
NAVER_CLIENT_ID=example-client-id
NAVER_CLIENT_SECRET=example-client-secret
OAUTH_CALLBACK_BASE_URL=http://127.0.0.1:3000
FRONTEND_APP_BASE_URL=http://127.0.0.1:4000
SENTRY_ENABLED=false
SENTRY_DSN_PRODUCER=
METRICS_ENABLED=true
METRICS_PORT=9100
SLOW_QUERY_THRESHOLD_MS=500
