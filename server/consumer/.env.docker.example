APP_ENV=development
POSTGRESQL_URL=postgresql://devuser:devpassword@postgres:5432/devdb
MONGODB_URL=mongodb://devuser:devpassword@mongodb:27017/devdb?authSource=admin
REDIS_URL=redis://redis:6379
KAFKA_CLIENT_ID=mealio-consumer
KAFKA_BROKERS=kafka:19092
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BATCH_MODEL=gpt-4.1-mini
PUBLIC_DATA_API_KEY=your-public-data-api-key
SENTRY_ENABLED=false
SENTRY_DSN_CONSUMER=
METRICS_ENABLED=true
METRICS_PORT=9091
SLOW_QUERY_THRESHOLD_MS=500
