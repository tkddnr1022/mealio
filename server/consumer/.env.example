NODE_ENV=development
POSTGRESQL_URL=postgresql://devuser:devpassword@localhost:5432/devdb
MONGODB_URL=mongodb://devuser:devpassword@localhost:27017/devdb?authSource=admin
REDIS_URL=redis://localhost:6379
KAFKA_CLIENT_ID=mealio-consumer
KAFKA_BROKERS=localhost:9092
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Sentry DSN (비우면 no-op). Kafka/DLQ/OpenAI 실패 보고.
SENTRY_DSN=
METRICS_ENABLED=true
METRICS_PORT=9091
SLOW_QUERY_THRESHOLD_MS=500
LOG_SAMPLE_RATE=1
TRACE_SAMPLE_RATE=1
