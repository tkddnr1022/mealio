# mongodb
MONGO_ROOT_USERNAME=devuser
MONGO_ROOT_PASSWORD=devpassword

# postgres
POSTGRES_USER=devuser
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=devdb

# kafka
KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9092

# kafka-ui
KAFKA_UI_PORT=8080
KAFKA_UI_CLUSTER_NAME=mealio
KAFKA_UI_BOOTSTRAP_SERVERS=kafka:19092

# prometheus
PROMETHEUS_TARGETS_MODE=host
PROMETHEUS_PORT=9090
PROMETHEUS_PRODUCER_PORT=3000
PROMETHEUS_CONSUMER_PORT=9091

# grafana
GRAFANA_PORT=3030
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_MONGODB_HOST=mongodb:27017
GRAFANA_MONGODB_USER=devuser
GRAFANA_MONGODB_PASSWORD=devpassword
GRAFANA_MONGODB_DATABASE=devdb
SLACK_OPS_WEBHOOK_URL=none
SLACK_PRODUCT_WEBHOOK_URL=none

# producer · consumer
NODE_ENV=development
METRICS_ENABLED=true
SENTRY_ENABLED=false
POSTGRESQL_URL=postgresql://devuser:devpassword@postgres:5432/devdb
MONGODB_URL=mongodb://devuser:devpassword@mongodb:27017/devdb?authSource=admin
REDIS_URL=redis://redis:6379
KAFKA_BROKERS=kafka:19092
SLOW_QUERY_THRESHOLD_MS=500

# producer
PORT=3000
SENTRY_DSN_PRODUCER=none
JWT_SECRET=a-string-secret-at-least-256-bits-long
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=1209600
REFRESH_TOKEN_BYTES=48
GOOGLE_CLIENT_ID=example.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=example-secret
KAKAO_CLIENT_ID=example-client-id
KAKAO_CLIENT_SECRET=example-client-secret
NAVER_CLIENT_ID=example-client-id
NAVER_CLIENT_SECRET=example-client-secret
OAUTH_CALLBACK_BASE_URL=http://localhost:3000
FRONTEND_APP_BASE_URL=http://localhost:4000
FRONTEND_OAUTH_ERROR_PATH=/oauth/error
FRONTEND_OAUTH_DEFAULT_SUCCESS_PATH=/recipe

# consumer
METRICS_PORT=9091
SENTRY_DSN_CONSUMER=none
OPENAI_API_KEY=sk-replace-me
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BATCH_MODEL=gpt-4.1-mini
PUBLIC_DATA_API_KEY=replace-me
