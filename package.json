{
  "name": "mealio-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Mealio monorepo (client, server/shared, server/producer, server/consumer)",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:client": "npm run build -w client",
    "build:storybook": "npm run build-storybook -w client",
    "build:producer": "npm run build -w server/producer",
    "build:consumer": "npm run build -w server/consumer",
    "build:shared": "npm run build -w server/shared",
    "start:client": "npm run dev -w client",
    "start:storybook": "npm run storybook -w client",
    "start:producer": "npm run start:dev -w server/producer",
    "start:consumer": "npm run start:dev -w server/consumer",
    "format": "prettier --write .",
    "verify:design-contrast": "node agent/common/verify-design-token-contrast.mjs",
    "ci": "pnpm run ci:install && pnpm run ci:build:server && pnpm run ci:test:producer",
    "ci:install": "pnpm install --frozen-lockfile",
    "ci:build:shared": "pnpm --filter @mealio/shared build",
    "ci:build:producer": "pnpm --filter @mealio/producer build",
    "ci:build:server": "pnpm run ci:build:shared && pnpm run ci:build:producer",
    "ci:test:producer": "pnpm --filter @mealio/producer test -- --passWithNoTests",
    "db:prisma:generate": "pnpm --filter @mealio/shared run prisma:generate",
    "db:prisma:migrate:dev": "pnpm --filter @mealio/shared run prisma:migrate:dev",
    "db:prisma:migrate:deploy": "pnpm --filter @mealio/shared run prisma:migrate:deploy",
    "db:prisma:seed": "pnpm --filter @mealio/shared run prisma:seed",
    "db:mongoose:seed": "pnpm --filter @mealio/shared run mongoose:seed"
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  },
  "workspaces": [
    "client",
    "server/shared",
    "server/producer",
    "server/consumer"
  ],
  "engines": {
    "node": ">=20"
  }
}
