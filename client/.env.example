# Public runtime mode (optional)
NODE_ENV=development

# Backend API base URL.
# Leave empty to use same-origin requests.
NEXT_PUBLIC_API_BASE_URL=

# Backend API prefix.
NEXT_PUBLIC_API_PREFIX=/api/v1

# JWT HttpOnly cookie name set by backend.
NEXT_PUBLIC_AUTH_COOKIE_NAME=accessToken
# Refresh HttpOnly cookie name set by backend.
NEXT_PUBLIC_REFRESH_COOKIE_NAME=refreshToken

# Optional canonical site URL (Open Graph, metadataBase). Omit on Vercel to use VERCEL_URL.
NEXT_PUBLIC_SITE_URL=

# --- Observability (SaaS-only: Sentry + GA4 + Vercel Analytics) ---

# Sentry browser DSN — staging/production 권장. 비우면 Sentry 비활성.
NEXT_PUBLIC_SENTRY_DSN=

# GA4 Measurement ID (e.g. G-XXXXXXXXXX) — staging/production 권장. 비우면 GA4 비활성.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional Sentry performance sample rate (0–1). Default: 0.1 prod, 1 dev.
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Vercel Analytics: Vercel 배포 시 대시보드에서 자동 수집(@vercel/analytics). 별도 env 불필요.
