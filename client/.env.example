# Public runtime mode (optional)
NODE_ENV=development

# Backend API base URL.
# Leave empty to use same-origin requests.
NEXT_PUBLIC_API_BASE_URL=

# Backend API prefix.
NEXT_PUBLIC_API_PREFIX=/api/v1

# JWT HttpOnly cookie name set by backend.
NEXT_PUBLIC_AUTH_COOKIE_NAME=accessToken
# Refresh HttpOnly cookie name set by backend.
NEXT_PUBLIC_REFRESH_COOKIE_NAME=refreshToken

# Optional canonical site URL (Open Graph, metadataBase). Omit on Vercel to use VERCEL_URL.
NEXT_PUBLIC_SITE_URL=

# Optional observability endpoint.
# Leave empty to disable.
NEXT_PUBLIC_OBSERVABILITY_ENDPOINT=
