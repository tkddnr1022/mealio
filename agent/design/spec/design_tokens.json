{
  "version": "2.3",
  "lastReviewed": "2026-04-21",
  "variables": {
    "figmaVariableAliases": {
      "figma-note": "Figma 변수명(slug) 기준. 값이 다른 변수를 가리키는 alias(= 동일 토큰 체인). canonical은 오른쪽.",
      "color/tab/active": "color/primary",
      "color/text/accent": "color/primary",
      "color/toggle/selected/default": "color/primary",
      "color/toggle/selected/hover": "color/primary-hover",
      "color/primary-inactive": "color/indicator/inactive",
      "color/chip/default": "color/background/primary",
      "color/chip/hover": "color/background/placeholder",
      "color/border/muted": "color/background/placeholder",
      "color/toggle/unselected/hover": "color/background/placeholder",
      "color/toggle/unselected/default": "color/background/primary",
      "color/secondary": "color/background/primary",
      "color/tag/default": "color/background/primary",
      "color/dropdown/unselected/hover": "color/background/primary",
      "card/elevation/color": "elevation/md/color",
      "card/elevation/x": "elevation/md/x",
      "card/elevation/y": "elevation/md/y",
      "card/elevation/blur": "elevation/md/blur"
    },
    "tokenAliasMap": {
      "figma-note": "`variables.*` 경로 간 alias. 키(별칭) → 값(canonical). 리프가 `{ aliasOf }`일 때와 동일 의미.",
      "variables.color.light.tab.active": "variables.color.light.primary.default",
      "variables.color.light.text.accent": "variables.color.light.primary.default",
      "variables.color.light.toggle.selected.default": "variables.color.light.primary.default",
      "variables.color.light.toggle.selected.hover": "variables.color.light.primary.hover",
      "variables.color.light.primary.inactive": "variables.color.light.indicator.inactive",
      "variables.color.light.chip.default": "variables.color.light.background.primary",
      "variables.color.light.chip.hover": "variables.color.light.background.placeholder",
      "variables.color.light.border.muted": "variables.color.light.background.placeholder",
      "variables.color.light.toggle.unselected.hover": "variables.color.light.background.placeholder",
      "variables.color.light.secondary.default": "variables.color.light.background.primary",
      "variables.color.light.tag.default": "variables.color.light.background.primary",
      "variables.color.light.dropdown.unselected.hover": "variables.color.light.background.primary",
      "variables.color.light.toggle.unselected.default": "variables.color.light.background.primary",
      "variables.color.dark.tab.active": "variables.color.dark.text.accent",
      "variables.color.dark.chip.default": "variables.color.dark.background.surface",
      "variables.color.dark.tag.default": "variables.color.dark.secondary.default",
      "variables.color.dark.dropdown.unselected.default": "variables.color.dark.background.surface",
      "variables.color.dark.dropdown.unselected.hover": "variables.color.dark.background.placeholder",
      "variables.card.elevation": "variables.elevation.md"
    },
    "content": {
      "logo": "Coop",
      "figma-note": "Figma 변수 `logo`(문자열). Navbar 브랜드 텍스트."
    },
    "border": {
      "width": {
        "default": 1,
        "focus": 2
      },
      "style": {
        "default": "solid"
      },
      "figma-note": "`border/default`·`border/focus` (px)."
    },
    "card": {
      "gap": 12,
      "padding": 16,
      "radius": 12,
      "elevation": {
        "aliasOf": "variables.elevation.md",
        "figma-note": "Figma `card/elevation/*`는 `elevation/md/*`와 동일 값(alias)."
      },
      "figma-note": "`card/gap`·`card/padding`·`card/radius`·`card/elevation/*`(alias → elevation/md)."
    },
    "elevation": {
      "sm": {
        "x": 0,
        "y": 1,
        "blur": 2,
        "color": "#0f172a0f"
      },
      "md": {
        "x": 0,
        "y": 4,
        "blur": 8,
        "color": "#0f172a14"
      },
      "figma-note": "`elevation/sm/*`·`elevation/md/*`."
    },
    "opacity": {
      "disabled": 0.5,
      "figma-note": "MCP 맵 `opacity/disabled`(0-1로 보관)."
    },
    "radius": {
      "lg": 8,
      "xl": 12,
      "2xl": 16,
      "full": 9999,
      "sm": 4,
      "md": 6,
      "figma-note": "Figma `radius/lg|xl|2xl|full`. sm·md는 코드 유틸(Figma 미정의)."
    },
    "size": {
      "sm": 16,
      "md": 20,
      "lg": 24,
      "2xl": 32,
      "figma-note": "`size/sm|md|lg|2xl`."
    },
    "spacing": {
      "1": 4,
      "2": 8,
      "3": 12,
      "4": 16,
      "5": 20,
      "6": 24,
      "7": 28,
      "8": 32,
      "10": 40,
      "11": 44,
      "12": 48,
      "16": 64,
      "touch-target-gap-token": "variables.spacing.2",
      "touch-target-gap-note": "design_principle platform.touchTargetSpacingMinPx(8px). Figma `spacing/2`.",
      "figma-note": "Figma `spacing/1|2|3|4|6|8|10`. 그 외 숫자 키는 globals 유틸."
    },
    "typography": {
      "fontFamily": "Noto Sans KR",
      "fontFamilyLogo": "Plus Jakarta Sans",
      "fontWeight": {
        "regular": 400,
        "medium": 500,
        "semibold": 600,
