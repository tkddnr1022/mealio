          "queryLanguage": "json",
          "queryText": "[{\"$match\":{\"type\":{\"$in\":[\"recipe.view\",\"recipe.favorites_add\"]}}},{\"$group\":{\"_id\":{\"date\":{\"$dateToString\":{\"format\":\"%Y-%m-%d\",\"date\":\"$occurredAt\"}},\"type\":\"$type\"},\"count\":{\"$sum\":1}}},{\"$group\":{\"_id\":\"$_id.date\",\"metrics\":{\"$push\":{\"type\":\"$_id.type\",\"count\":\"$count\"}}}},{\"$project\":{\"time\":{\"$toDate\":\"$_id\"},\"views\":{\"$let\":{\"vars\":{\"v\":{\"$filter\":{\"input\":\"$metrics\",\"as\":\"m\",\"cond\":{\"$eq\":[\"$$m.type\",\"recipe.view\"]}}}},\"in\":{\"$ifNull\":[{\"$arrayElemAt\":[\"$$v.count\",0]},0]}}},\"favorites\":{\"$let\":{\"vars\":{\"f\":{\"$filter\":{\"input\":\"$metrics\",\"as\":\"m\",\"cond\":{\"$eq\":[\"$$m.type\",\"recipe.favorites_add\"]}}}},\"in\":{\"$ifNull\":[{\"$arrayElemAt\":[\"$$f.count\",0]},0]}}}}},{\"$sort\":{\"time\":1}}]",
          "refId": "A"
