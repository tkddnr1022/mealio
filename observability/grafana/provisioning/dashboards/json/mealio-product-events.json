      "title": "Chatbot DAU (daily)",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "collection": "event_logs",
          "queryLanguage": "json",
          "queryText": "[{\"$match\":{\"type\":\"chatbot.message\",\"actor.userId\":{\"$exists\":true,\"$ne\":null}}},{\"$group\":{\"_id\":{\"$dateToString\":{\"format\":\"%Y-%m-%d\",\"date\":\"$occurredAt\"}},\"users\":{\"$addToSet\":\"$actor.userId\"}}},{\"$project\":{\"time\":{\"$toDate\":\"$_id\"},\"dau\":{\"$size\":\"$users\"}}},{\"$sort\":{\"time\":1}}]",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "haohanyang-mongodb-datasource",
        "uid": "mongodb"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "title": "Recipe views vs favorites (daily count)",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
