      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 6,
      "title": "Seconds since last CLI push",
      "type": "timeseries",
      "targets": [
        {
          "expr": "max by (stage) (time() - push_time_seconds{job=\"recipe_ingestion_cli\"})",
          "legendFormat": "stage={{stage}}",
          "refId": "A"
        }
