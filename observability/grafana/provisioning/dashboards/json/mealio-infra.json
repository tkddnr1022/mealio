    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 7,
      "title": "Pushgateway metric groups",
      "type": "timeseries",
      "targets": [
        {
          "expr": "count by (job, stage) (recipe_ingestion_stage_total{job=\"recipe_ingestion_cli\"})",
          "legendFormat": "{{job}} {{stage}}",
          "refId": "A"
        }
      ]
