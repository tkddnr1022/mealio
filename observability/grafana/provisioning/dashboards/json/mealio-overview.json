      "title": "Consumer lag by topic",
      "type": "timeseries",
      "targets": [
        {
          "expr": "max(kafka_consumer_lag{service=\"consumer\"}) by (topic, consumer_group)",
          "legendFormat": "{{topic}} / {{consumer_group}}",
          "refId": "A"
        }
