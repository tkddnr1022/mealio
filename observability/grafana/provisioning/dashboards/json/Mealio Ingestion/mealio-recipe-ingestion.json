          "expr": "sum by (stage) (increase(recipe_ingestion_stage_total{outcome=\"failed\"}[24h])) / clamp_min(sum by (stage) (increase(recipe_ingestion_stage_total[24h])), 1)",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
