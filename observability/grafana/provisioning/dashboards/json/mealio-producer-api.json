      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"producer\", status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{service=\"producer\"}[5m])), 1e-9)",
