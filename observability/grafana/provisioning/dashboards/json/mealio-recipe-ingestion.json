          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, stage) (rate(recipe_ingestion_stage_latency_ms_bucket[5m])))",
          "legendFormat": "{{stage}} p50",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
