      "title": "Outcome breakdown (failed / skipped)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (stage, outcome) (rate(recipe_ingestion_stage_total{outcome=~\"failed|skipped\"}[5m]))",
          "legendFormat": "{{stage}} {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
